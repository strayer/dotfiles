#!/bin/bash
# chezmoi-secrets: age-encrypted secrets management for chezmoi
# Uses age-plugin-se (Secure Enclave) for decryption.
#
# Subcommands:
#   get   - Decrypt and output secrets YAML to stdout (default)
#   edit  - Decrypt to temp file, open $EDITOR, re-encrypt on save

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR
readonly IDENTITY_FILE="${HOME}/.config/chezmoi/age-identity.txt"

die() {
  echo "Error: $1" >&2
  exit 1
}

# Find a file by name, first relative to script location, then via chezmoi.
# With --init, returns the default path instead of failing when the file doesn't exist.
find_source_file() {
  local init=false
  if [[ "${1:-}" == "--init" ]]; then
    init=true
    shift
  fi
  local filename="$1"

  local candidate="${SCRIPT_DIR}/../${filename}"
  if [[ -f "$candidate" ]]; then
    echo "$candidate"
    return
  fi

  local source_dir
  source_dir="$(chezmoi source-path 2>/dev/null)" || true
  if [[ -n "$source_dir" && -f "${source_dir}/${filename}" ]]; then
    echo "${source_dir}/${filename}"
    return
  fi

  if [[ "$init" == true ]]; then
    echo "${SCRIPT_DIR}/../${filename}"
    return
  fi

  die "Cannot find ${filename}"
}

cmd_get() {
  [[ -f "$IDENTITY_FILE" ]] || die "Identity file not found: ${IDENTITY_FILE}
Generate one with: age-plugin-se keygen -o ${IDENTITY_FILE}"

  local secrets_file
  secrets_file="$(find_source_file .chezmoisecrets.age)"

  age -d -i "$IDENTITY_FILE" "$secrets_file"
}

cmd_edit() {
  [[ -f "$IDENTITY_FILE" ]] || die "Identity file not found: ${IDENTITY_FILE}"

  local secrets_file recipients_file tmp_file
  secrets_file="$(find_source_file --init .chezmoisecrets.age)"
  recipients_file="$(find_source_file .chezmoisecrets-recipients.txt)"

  tmp_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$tmp_file'" EXIT

  if [[ -f "$secrets_file" ]]; then
    age -d -i "$IDENTITY_FILE" "$secrets_file" > "$tmp_file"
  fi

  "${EDITOR:-vi}" "$tmp_file"

  age -e -R "$recipients_file" -o "$secrets_file" "$tmp_file"
  echo "Secrets updated: ${secrets_file}"
}

case "${1:-get}" in
  get)  cmd_get ;;
  edit) cmd_edit ;;
  *)    die "Usage: $(basename "${BASH_SOURCE[0]}") [get|edit]" ;;
esac
