#!/usr/bin/env bash
set -euo pipefail

config_dir="${DOT_SECRET_DIR:-${HOME}/.config/dot-secret}"
backend_file="${DOT_SECRET_BACKEND_FILE:-${config_dir}/backend}"

usage() {
  cat >&2 <<'EOF'
usage: dot-secret {get NAME|set NAME|list}
EOF
}

case "${1:-}" in
  get|set)
    if [[ $# -ne 2 ]]; then
      usage
      exit 2
    fi
    ;;
  list)
    if [[ $# -ne 1 ]]; then
      usage
      exit 2
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac

if [[ ! -r "$backend_file" ]]; then
  cat >&2 <<EOF
dot-secret: backend selector not found: $backend_file

Run:
  chezmoi apply
EOF
  exit 1
fi

backend="$(tr -d '[:space:]' < "$backend_file")"
if [[ ! "$backend" =~ ^[a-z][a-z0-9_-]*$ ]]; then
  echo "dot-secret: invalid backend selector" >&2
  exit 1
fi

impl="${config_dir}/impls/${backend}"
if [[ ! -x "$impl" ]]; then
  cat >&2 <<EOF
dot-secret: selected backend is unavailable: $backend

Run:
  chezmoi apply
EOF
  exit 1
fi

exec "$impl" "$@"
