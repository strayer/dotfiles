#!/bin/dash
# rift shim — resolves the rift agent binary at call time.
# Uses dash (POSIX sh) for faster startup than bash.
#
# Prefers a local dev build under ~/dev/rift/target/release so local changes can
# be tested without touching Homebrew. Falls back to the Homebrew-installed
# binary when the dev build is absent, so a plain `cargo clean` transparently
# restores the Homebrew version with no extra steps.
#
# Because ~/.bin is first on PATH, `rift service install` resolves the agent
# executable to this shim and writes it into the launchd plist. The service then
# re-runs the shim on every (re)start and picks dev-vs-Homebrew at that moment —
# so `cargo clean && rift service restart` is enough to switch back to Homebrew.
dev="$HOME/dev/rift/target/release/rift"
if [ -x "$dev" ]; then
  exec "$dev" "$@"
fi
exec /opt/homebrew/bin/rift "$@"
