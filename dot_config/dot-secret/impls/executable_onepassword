#!/usr/bin/env bash
set -euo pipefail

# 1Password backend for dot-secret.
#
# Convention: every secret lives in a dedicated "dot-secret" vault as an item
# named after the secret, in the "credential" field:
#
#   op://dot-secret/<name>/credential
#
# The reference is derived from the secret name alone — there are no vault,
# item, or field names specific to any real layout here — so this script is
# safe to keep unencrypted in a public repo. Scoping a 1Password service
# account / agent to just the "dot-secret" vault keeps the blast radius to
# these keys if a consumer is ever compromised.

vault="${DOT_SECRET_OP_VAULT:-dot-secret}"

usage() {
  cat >&2 <<'EOF'
usage: dot-secret {get NAME|set NAME|list}
EOF
}

ref_for() {
  printf 'op://%s/%s/credential\n' "$vault" "$1"
}

case "${1:-}" in
  list)
    [[ $# -eq 1 ]] || { usage; exit 2; }
    op item list --vault "$vault" --format json | jq -r '.[].title'
    ;;
  get)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    exec op read "$(ref_for "$2")"
    ;;
  set)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    cat >&2 <<EOF
dot-secret: set is managed in 1Password for this backend.
Create or edit item "$2" (field "credential") in the "$vault" vault.
EOF
    exit 1
    ;;
  *)
    usage
    exit 2
    ;;
esac
