{
  "$schema": "./nono-profile.schema.json",
  "extends": "claude-code-base",
  "meta": {
    "name": "claude-code"
  },
  "filesystem": {
    "deny": [
      "/var/run/docker.sock",
      "$HOME/.orbstack/run/docker.sock"
    ]
  },
  "commands": {
    "deny": [
      "docker",
      "docker-compose",
      "podman",
      "kubectl"
    ]
  }
}
